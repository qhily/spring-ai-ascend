# Spring AI Ascend — agent-runtime-a2a-llm-e2e sample configuration.
# Copy to `.env` (gitignored) and fill in your model service, then run:
#   bash scripts/test-e2e.sh .env            (Linux/WSL/macOS)
#   ./scripts/test-e2e.ps1 -EnvFile .env     (Windows PowerShell)
#
# IMPORTANT: the real-LLM e2e (OpenJiuwenReactAgentA2aE2eTest) only runs when
# SAA_SAMPLE_LLM_API_KEY is non-blank. Without it, JUnit assumeTrue() SKIPS the
# real-LLM branch after the agent-card check (the rest of the suite still runs).

# Any non-blank value enables the real-LLM e2e branch (use your provider's key/token).
SAA_SAMPLE_LLM_API_KEY=
# openai = OpenAI-compatible /v1 (OpenAI, LiteLLM, Ollama /v1, vLLM, Azure-OpenAI-compat, ...).
SAA_SAMPLE_OPENJIUWEN_MODEL_PROVIDER=openai
# Base URL of an OpenAI-compatible endpoint.
SAA_SAMPLE_OPENJIUWEN_API_BASE=http://localhost:4000/v1
# AgentScope Java SDK uses the same OpenAI-compatible endpoint by default.
SAA_SAMPLE_AGENTSCOPE_API_BASE=http://localhost:4000/v1
# AgentScope OpenAI-compatible chat-completions path.
SAA_SAMPLE_AGENTSCOPE_ENDPOINT_PATH=/chat/completions
# Model name served by that endpoint.
SAA_SAMPLE_LLM_MODEL=gpt-5.4-mini
# TLS verification (false for local http endpoints; true for cloud https).
SAA_SAMPLE_OPENJIUWEN_SSL_VERIFY=false
# Optional external AgentScope REST/SSE runtimes. Leave `self` for embedded samples.
SAA_SAMPLE_AGENTSCOPE_RUNTIME_BASE_URL=self
SAA_SAMPLE_RETAIL_WEALTH_RUNTIME_BASE_URL=self
# Local-only route-grant signing secret. Override before sharing authorization demos.
SAA_SAMPLE_GATEWAY_ROUTE_GRANT_SECRET=agent-examples-local-route-grant-secret

# --- LLM egress gateway path (optional) ---
# true routes BOTH framework samples through the local agent-runtime LLM gateway
# (/v1, minted token) instead of calling the upstream directly; the alias routing
# table in application.yaml keeps pointing at SAA_SAMPLE_OPENJIUWEN_API_BASE above.
SAA_SAMPLE_LLM_VIA_GATEWAY=false
# Gateway surface the samples call when the flip is on (the sample server itself).
SAA_SAMPLE_LLM_GATEWAY_BASE_URL=http://localhost:8080/v1
# Minted token + model alias; must match the application.yaml token map key and alias.
SAA_SAMPLE_LLM_GATEWAY_TOKEN=saa-sample-minted-token
SAA_SAMPLE_LLM_GATEWAY_MODEL_ALIAS=sample-llm
